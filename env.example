# Lightspeed OAuth2 Credentials
# URL base de la API (sin /V3, sin /Account/{id})
# Ejemplo: https://api.lightspeedapp.com o https://us.merchantos.com
LIGHTSPEED_API_URL=https://api.lightspeedapp.com
# Alternativamente puedes usar LIGHTSPEED_API_BASE_URL con la URL completa: https://api.lightspeedapp.com/API
LIGHTSPEED_OAUTH_URL=https://cloud.lightspeedapp.com/oauth/access_token.php
LIGHTSPEED_CLIENT_ID=your_client_id
LIGHTSPEED_CLIENT_SECRET=your_client_secret
LIGHTSPEED_REFRESH_TOKEN=your_refresh_token
LIGHTSPEED_ACCOUNT_ID=your_account_id

# Database Configuration (soporta DATABASE_* o DB_*)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lightspeed_sync
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# Scheduler Configuration
POLLING_INTERVAL_HOURS=3
POLLING_CRON_EXPRESSION=0 */3 * * *  # Cada 3 horas

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BACKOFF_MS=1000

# Logging
LOG_LEVEL=info

# CONTPAQi Configuration (opcional)
CONTAPAQI_API_URL=http://localhost:88/
CONTAPAQI_USERNAME=USUARIO
CONTAPAQI_PASSWORD=12345

